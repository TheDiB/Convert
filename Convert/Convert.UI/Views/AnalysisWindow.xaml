<Window x:Class="Convert.UI.Views.AnalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding Title}"
        Style="{StaticResource MaterialDesignWindow}"
        Width="900" Height="1000"
        ResizeMode="NoResize"        
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="940"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>

        <Button Content="Copier"
            Grid.Row="1"
            Padding="10 0 10 0"
            Margin="0 -20 80 0"
            HorizontalAlignment="Right"
            Command="{Binding CopyCommand}" />

        <Button Content="Fermer"
            Grid.Row="1"
            Padding="10 0 10 0"            
                Margin="0 -20 10 0"
            HorizontalAlignment="Right"
            Command="{Binding CloseCommand}" />

        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="0" Margin="0 0 0 20">
            <TextBox Text="{Binding AnalysisText}"
                    FontFamily="Consolas"                
                    FontSize="13"
                    AcceptsReturn="True"
                    AcceptsTab="True"
                    TextWrapping="NoWrap"
                    IsReadOnly="True"
                    BorderThickness="0"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Auto" />
        </ScrollViewer>
    </Grid>
</Window>
